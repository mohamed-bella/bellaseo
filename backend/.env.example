# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── AI Provider ──────────────────────────────────────────────────────────────
AI_PROVIDER=openai           # openai | gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=               # used if AI_PROVIDER=gemini
GEMINI_MODEL=gemini-1.5-pro

# ─── WordPress (global fallback — overridden per site in DB) ──────────────────
WP_DEFAULT_USERNAME=
WP_DEFAULT_APP_PASSWORD=

# ─── Blogger (Google OAuth2) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ─── WhatsApp (Baileys) ───────────────────────────────────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_PHONE=              # Your number e.g. 1234567890@s.whatsapp.net

# ─── Security ─────────────────────────────────────────────────────────────────
API_SECRET=your-strong-random-secret
CORS_ORIGIN=http://localhost:3000

# ─── E-E-A-T Authority Engine ──────────────────────────────────────────────────
SERPER_API_KEY=                      # Get free key at https://serper.dev (2,500 searches/month free)

# Google Indexing API (optional — instant URL submission to Google after publish)
GOOGLE_INDEXING_ENABLED=false        # Set to true to activate
GOOGLE_INDEXING_KEY_FILE=            # Absolute path to your GCP service account JSON key
